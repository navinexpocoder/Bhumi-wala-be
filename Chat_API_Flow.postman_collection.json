{
  "info": {
    "_postman_id": "9eea2ef4-8cbe-4b0b-9053-e5c2c8d7ef11",
    "name": "Bhumi Chat API - Buyer Seller Flow",
    "description": "Ordered flow collection for buyer-seller chat validation. Includes auth login for both users and chained chat requests with tests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "buyerEmail",
      "value": ""
    },
    {
      "key": "buyerPassword",
      "value": ""
    },
    {
      "key": "sellerEmail",
      "value": ""
    },
    {
      "key": "sellerPassword",
      "value": ""
    },
    {
      "key": "buyerToken",
      "value": ""
    },
    {
      "key": "sellerToken",
      "value": ""
    },
    {
      "key": "propertyId",
      "value": ""
    },
    {
      "key": "conversationId",
      "value": ""
    },
    {
      "key": "notificationId",
      "value": ""
    },
    {
      "key": "page",
      "value": "1"
    },
    {
      "key": "limit",
      "value": "20"
    }
  ],
  "item": [
    {
      "name": "00) Auth Setup",
      "item": [
        {
          "name": "Login Buyer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{buyerEmail}}\",\n  \"password\": \"{{buyerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Buyer login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Buyer token present', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.have.property('token');",
                  "});",
                  "",
                  "pm.collectionVariables.set('buyerToken', json.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Seller",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{sellerEmail}}\",\n  \"password\": \"{{sellerPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Seller login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Seller token present', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.have.property('token');",
                  "});",
                  "",
                  "pm.collectionVariables.set('sellerToken', json.data.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01) Buyer Flow",
      "item": [
        {
          "name": "Buyer - Create/Get Conversation",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Conversation id exists', function () {",
                  "  pm.expect(json).to.have.property('data');",
                  "  pm.expect(json.data).to.have.property('_id');",
                  "});",
                  "",
                  "pm.collectionVariables.set('conversationId', json.data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Buyer - Get Conversations",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations?page={{page}}&limit={{limit}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            }
          }
        },
        {
          "name": "Buyer - Get Messages",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations/{{conversationId}}/messages?page=1&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations",
                "{{conversationId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Buyer - Mark Messages Seen",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations/{{conversationId}}/seen",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations",
                "{{conversationId}}",
                "seen"
              ]
            }
          }
        },
        {
          "name": "Buyer - Unread Summary",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{buyerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/unread-summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "unread-summary"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "02) Seller Flow",
      "item": [
        {
          "name": "Seller - Get Conversations",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations?page={{page}}&limit={{limit}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "limit",
                  "value": "{{limit}}"
                }
              ]
            }
          }
        },
        {
          "name": "Seller - Get Messages",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/conversations/{{conversationId}}/messages?page=1&limit=50",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "conversations",
                "{{conversationId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        },
        {
          "name": "Seller - Get Notifications",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/notifications?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "notifications"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.data && Array.isArray(json.data.notifications) && json.data.notifications.length > 0) {",
                  "  pm.collectionVariables.set('notificationId', json.data.notifications[0]._id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Seller - Mark One Notification Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/chat/notifications/{{notificationId}}/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "notifications",
                "{{notificationId}}",
                "read"
              ]
            }
          }
        },
        {
          "name": "Seller - Mark All Notifications Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/chat/notifications/read-all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "notifications",
                "read-all"
              ]
            }
          }
        },
        {
          "name": "Seller - Unread Summary",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{sellerToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/chat/unread-summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "chat",
                "unread-summary"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "03) Notes",
      "item": [
        {
          "name": "Realtime Socket Note",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Postman collection validates REST flow only. Realtime events (sendMessage, receiveMessage, newNotification) should be tested via frontend clients or a Socket.IO test client."
          }
        }
      ]
    }
  ]
}
